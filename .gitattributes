# Normalize line endings and text handling
* text=auto eol=lf

# Explicit text formats
*.md   text eol=lf
*.py   text eol=lf
*.json text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.txt  text eol=lf

# Keep binary untouched
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.zip  binary
*.skill binary
